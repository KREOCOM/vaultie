# Local Python virtualenv the Firebase CLI creates for packaging/emulation.
venv/
.venv/
__pycache__/
*.pyc

# Never commit secrets or exported keys.
*.pem
.env
.env.*
.runtimeconfig.json

# Dev-only: real bank-data fixtures + offline Stage-2 tooling.
# MUST NEVER be committed or bundled into a Cloud Functions deploy.
# (entity.py is now production — imported by resolver.py — so it is tracked.)
fixtures/
diag.py
bench_entity.py

# Global merchant fallback index — a large build artifact (~461MB) compiled offline
# by tools/kb_build/build_index.py. Not tracked in git (would bloat the repo); it is
# built and placed here for deploy. Resolver runs main-KB-only if it is absent.
kb/merchant_index.sqlite
