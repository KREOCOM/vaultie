<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ system splash (light mode): vault-green background with the
         white "V" logo, so it matches the Flutter splash and reads as one. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/vaultie_splash</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_transparent</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
