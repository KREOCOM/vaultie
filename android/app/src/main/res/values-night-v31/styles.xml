<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ system splash (dark mode): same vault-green splash so the
         background never differs from the Flutter splash. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/vaultie_splash</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_transparent</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
