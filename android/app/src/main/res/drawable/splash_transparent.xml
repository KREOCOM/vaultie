<?xml version="1.0" encoding="utf-8"?>
<!-- Fully transparent drawable used as the Android 12+ splash icon so the OS
     splash is just the solid green background — the branded logo then appears
     only once, in the Flutter splash, so it reads as a single splash. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@android:color/transparent" />
</shape>
